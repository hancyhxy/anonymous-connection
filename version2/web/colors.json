{
  "_meta": {
    "source": "v5: 2D palette (mood × energy). Base hex values informed by hello-stranger's original 1D energy scale (MIT, The Pudding, 2022), then re-curated per mood-row to shift hue/temperature while energy still controls brightness/saturation within each row.",
    "reference": "hello-stranger upstream: https://pudding.cool/2025/06/hello-stranger/ (MIT, 2022)",
    "v5_note": "mood is now a color axis, not an animation axis. Animation tempo is a hidden constant in app.js (ANIM_INTERVAL_MS). Smile is a direct user dimension (Q_SMILE). renderer.js reads colors.palette[state.mood][state.bg_level].hex and derives character / bg / border via the unchanged hello-stranger darken/lighten/darkest algorithm."
  },

  "mood": {
    "0": { "key": "chill",    "note": "relaxed / grounded — olive → chartreuse. Yellow-green family with a subtle highlighter feel; separated from curious's blue so the two moods read distinctly." },
    "1": { "key": "curious",  "note": "alert / open — cyan → sky blue." },
    "2": { "key": "playful",  "note": "HAPPY — magenta → pink → hot pink. The user's 'purple-pink' family for joy." },
    "3": { "key": "tired",    "note": "drained — grey → warm grey → taupe. The user's 'grey' family for exhaustion." },
    "4": { "key": "glowing",  "note": "radiant — gold → warm orange → amber." }
  },

  "palette": {
    "0": {
      "0": { "key": "chill-empty",    "hex": "#3d4a2a" },
      "1": { "key": "chill-low",      "hex": "#5a6b38" },
      "2": { "key": "chill-medium",   "hex": "#7a8a48" },
      "3": { "key": "chill-steady",   "hex": "#8aa84a" },
      "4": { "key": "chill-high",     "hex": "#9ec040" },
      "5": { "key": "chill-electric", "hex": "#a8c828" }
    },
